generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  body        String
  category    Category
  priority    Priority
  publishDate DateTime
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Category {
  EXAM
  EVENT
  GENERAL
}

enum Priority {
  NORMAL
  URGENT
}
